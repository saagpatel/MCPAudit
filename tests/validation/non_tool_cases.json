      {
        "target_type": "prompt",
        "target_name": "review_code",
        "category": "network",
        "min_confidence": "medium"
      },
      {
        "target_type": "resource",
        "target_name": "https://docs.example.com/{tenant}/index.json",
        "category": "network",
        "min_confidence": "high"
      }
    ],
    "expected_injections": [
      {
        "target_type": "prompt",
        "target_name": "review_code",
        "severity": "high",
        "pattern_name": "ignore_instructions"
