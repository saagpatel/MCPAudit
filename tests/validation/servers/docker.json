        "required": ["image"]
      }
    },
    {
      "name": "docker_remove_container",
      "description": "Remove a container by id or name.",
      "input_schema": {
        "type": "object",
        "properties": {
          "container_id": { "type": "string" }
        },
        "required": ["container_id"]
      }
    }
  ],
  "expected_findings": [
    {
