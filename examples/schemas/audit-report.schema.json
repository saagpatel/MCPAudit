{
  "$defs": {
    "CapabilityFinding": {
      "description": "A permission inference for a non-tool MCP capability.",
      "properties": {
        "target_type": {
          "$ref": "#/$defs/CapabilityTarget"
        },
        "target_name": {
          "title": "Target Name",
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/PermissionCategory"
        },
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "evidence": {
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        }
      },
      "required": [
        "target_type",
        "target_name",
        "category",
        "confidence",
        "evidence"
      ],
      "title": "CapabilityFinding",
      "type": "object"
    },
    "CapabilityTarget": {
      "enum": [
        "tool",
        "prompt",
        "resource"
      ],
      "title": "CapabilityTarget",
      "type": "string"
    },
    "ClientType": {
      "enum": [
        "claude_desktop",
        "claude_code",
        "cursor",
        "vscode",
        "windsurf"
      ],
      "title": "ClientType",
      "type": "string"
    },
    "Confidence": {
      "enum": [
        "declared",
        "high",
        "medium",
        "low",
        "manual",
        "llm"
      ],
      "title": "Confidence",
      "type": "string"
    },
    "ConfigHealthFinding": {
      "description": "A configuration health warning found before connecting to an MCP server.",
      "properties": {
        "finding_type": {
          "title": "Finding Type",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/ConfigHealthSeverity"
        },
        "server_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Server Name"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "details": {
          "items": {
            "type": "string"
          },
          "title": "Details",
          "type": "array"
        },
        "remediation": {
          "title": "Remediation",
          "type": "string"
        }
      },
      "required": [
        "finding_type",
        "severity",
        "summary",
        "remediation"
      ],
      "title": "ConfigHealthFinding",
      "type": "object"
    },
    "ConfigHealthSeverity": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "ConfigHealthSeverity",
      "type": "string"
    },
    "DriftFinding": {
      "description": "A change detected between pinned and current tool schema.",
      "properties": {
        "server_name": {
          "title": "Server Name",
          "type": "string"
        },
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/DriftStatus"
        },
        "stored_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stored Hash"
        },
        "current_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Hash"
        },
        "pinned_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pinned At"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        },
        "details": {
          "items": {
            "type": "string"
          },
          "title": "Details",
          "type": "array"
        },
        "remediation": {
          "default": "",
          "title": "Remediation",
          "type": "string"
        }
      },
      "required": [
        "server_name",
        "tool_name",
        "status"
      ],
      "title": "DriftFinding",
      "type": "object"
    },
    "DriftStatus": {
      "enum": [
        "new",
        "changed",
        "removed"
      ],
      "title": "DriftStatus",
      "type": "string"
    },
    "EscalationFinding": {
      "description": "A capability-escalation / rug-pull finding detected against the pin baseline.\n\nFires only when a tool DIFFERS from its operator-blessed pin baseline in a\nsecurity-significant way:\n  CAPABILITY            \u2014 the tool gained a dangerous permission category it\n                          did not hold when pinned (e.g. read-only \u2192 file_write,\n                          exfiltration, shell_execution, destructive).\n  DESCRIPTION_INJECTION \u2014 the tool's description gained prompt-injection\n                          pattern(s) absent from the pinned baseline.\n\nPurely a delta against the pin store: a tool matching its baseline produces no\nfinding, so the false-positive rate is near-zero by construction.  Requires a\npin baseline (``--escalation-check`` implies pin comparison).",
      "properties": {
        "kind": {
          "$ref": "#/$defs/EscalationKind"
        },
        "severity": {
          "$ref": "#/$defs/EscalationSeverity"
        },
        "server_name": {
          "title": "Server Name",
          "type": "string"
        },
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        },
        "gained_categories": {
          "items": {
            "$ref": "#/$defs/PermissionCategory"
          },
          "title": "Gained Categories",
          "type": "array"
        },
        "gained_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Gained Patterns",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "severity",
        "server_name",
        "tool_name",
        "description"
      ],
      "title": "EscalationFinding",
      "type": "object"
    },
    "EscalationKind": {
      "enum": [
        "capability",
        "description_injection"
      ],
      "title": "EscalationKind",
      "type": "string"
    },
    "EscalationSeverity": {
      "enum": [
        "high",
        "medium"
      ],
      "title": "EscalationSeverity",
      "type": "string"
    },
    "InjectionFinding": {
      "description": "A prompt injection threat detected in a tool's description or name.",
      "properties": {
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        },
        "target_type": {
          "$ref": "#/$defs/CapabilityTarget",
          "default": "tool"
        },
        "target_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Name"
        },
        "severity": {
          "$ref": "#/$defs/InjectionSeverity"
        },
        "pattern_name": {
          "title": "Pattern Name",
          "type": "string"
        },
        "matched_text": {
          "title": "Matched Text",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "tool_name",
        "severity",
        "pattern_name",
        "matched_text",
        "description"
      ],
      "title": "InjectionFinding",
      "type": "object"
    },
    "InjectionSeverity": {
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "title": "InjectionSeverity",
      "type": "string"
    },
    "IntegrityFinding": {
      "description": "A launch-artifact integrity change detected against the pin baseline.\n\nFires when the on-disk artifact that a server launches (the resolved command\nbinary, or a local script passed as an argument) has different bytes than\nwhen it was pinned \u2014 a supply-chain signal the schema and provenance checks\ncannot see, because the command string can stay byte-identical while the file\nit points at is swapped underneath you.\n\nARTIFACT_DRIFT covers two cases: the file's SHA-256 changed (HIGH), or the\npinned file is gone from its path (MEDIUM \u2014 often a relocation, but worth a\nlook). Offline and deterministic: only on-disk bytes are hashed; nothing is\nfetched. Requires a pin baseline that captured artifact hashes\n(``--integrity-check`` implies a pin comparison; baselines pinned before this\nfeature are skipped until re-pinned). Package-runner launches (``npx``/``uvx``)\nhash the runner binary, not the remote package \u2014 registry-artifact\nverification is a separate, network-gated follow-up.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/IntegrityKind"
        },
        "severity": {
          "$ref": "#/$defs/IntegritySeverity"
        },
        "server_name": {
          "title": "Server Name",
          "type": "string"
        },
        "artifact_path": {
          "title": "Artifact Path",
          "type": "string"
        },
        "baseline_hash": {
          "title": "Baseline Hash",
          "type": "string"
        },
        "current_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Current Hash"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "severity",
        "server_name",
        "artifact_path",
        "baseline_hash",
        "current_hash",
        "summary"
      ],
      "title": "IntegrityFinding",
      "type": "object"
    },
    "IntegrityKind": {
      "enum": [
        "artifact_drift"
      ],
      "title": "IntegrityKind",
      "type": "string"
    },
    "IntegritySeverity": {
      "enum": [
        "high",
        "medium"
      ],
      "title": "IntegritySeverity",
      "type": "string"
    },
    "NonToolRisk": {
      "description": "Additive prompt/resource risk indicator for non-tool MCP capabilities.",
      "properties": {
        "composite": {
          "maximum": 10,
          "minimum": 0,
          "title": "Composite",
          "type": "number"
        },
        "capability_score": {
          "maximum": 10,
          "minimum": 0,
          "title": "Capability Score",
          "type": "number"
        },
        "injection_score": {
          "maximum": 10,
          "minimum": 0,
          "title": "Injection Score",
          "type": "number"
        },
        "prompt_findings": {
          "minimum": 0,
          "title": "Prompt Findings",
          "type": "integer"
        },
        "resource_findings": {
          "minimum": 0,
          "title": "Resource Findings",
          "type": "integer"
        },
        "high_severity_findings": {
          "minimum": 0,
          "title": "High Severity Findings",
          "type": "integer"
        },
        "note": {
          "default": "Additive prompt/resource risk indicator; does not affect risk_score.composite.",
          "title": "Note",
          "type": "string"
        }
      },
      "required": [
        "composite",
        "capability_score",
        "injection_score",
        "prompt_findings",
        "resource_findings",
        "high_severity_findings"
      ],
      "title": "NonToolRisk",
      "type": "object"
    },
    "PackageVerifyFinding": {
      "description": "A registry-published package hash change detected against the pin baseline.\n\nThe on-disk integrity check (MCP024) hashes local bytes; for package-runner\nlaunches (``npx pkg@x`` / ``uvx pkg``) the meaningful artifact is the remote\npackage, not the runner binary. This finding compares the registry-published\nhash for a pinned ``package@version`` against the hash captured at pin time:\n\n  REGISTRY_DRIFT \u2014 the registry's published hash for the exact pinned version\n                   changed (HIGH, a republish-in-place / tampering signal), or\n                   it could not be re-fetched to verify (MEDIUM).\n\nNetwork-gated: only populated under ``--verify-artifacts`` (opt-in), and the\nbaseline hash is captured only when pinning with ``--verify-artifacts``. A\nversion *float* (different version than pinned) is provenance's job (MCP021),\nnot this check, which keys by exact ``package@version``.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/PackageVerifyKind"
        },
        "severity": {
          "$ref": "#/$defs/PackageVerifySeverity"
        },
        "server_name": {
          "title": "Server Name",
          "type": "string"
        },
        "ecosystem": {
          "title": "Ecosystem",
          "type": "string"
        },
        "package": {
          "title": "Package",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "baseline_hash": {
          "title": "Baseline Hash",
          "type": "string"
        },
        "current_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Current Hash"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "severity",
        "server_name",
        "ecosystem",
        "package",
        "version",
        "baseline_hash",
        "current_hash",
        "summary"
      ],
      "title": "PackageVerifyFinding",
      "type": "object"
    },
    "PackageVerifyKind": {
      "enum": [
        "registry_drift"
      ],
      "title": "PackageVerifyKind",
      "type": "string"
    },
    "PackageVerifySeverity": {
      "enum": [
        "high",
        "medium"
      ],
      "title": "PackageVerifySeverity",
      "type": "string"
    },
    "PermissionCategory": {
      "enum": [
        "file_read",
        "file_write",
        "network",
        "shell_execution",
        "destructive",
        "exfiltration"
      ],
      "title": "PermissionCategory",
      "type": "string"
    },
    "PermissionFinding": {
      "description": "A single permission inference for a tool.",
      "properties": {
        "category": {
          "$ref": "#/$defs/PermissionCategory"
        },
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "evidence": {
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        },
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        }
      },
      "required": [
        "category",
        "confidence",
        "evidence",
        "tool_name"
      ],
      "title": "PermissionFinding",
      "type": "object"
    },
    "PolicyResult": {
      "description": "Result of evaluating an audit report against a local policy file.",
      "properties": {
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "violations": {
          "items": {
            "$ref": "#/$defs/PolicyViolation"
          },
          "title": "Violations",
          "type": "array"
        }
      },
      "required": [
        "passed"
      ],
      "title": "PolicyResult",
      "type": "object"
    },
    "PolicyViolation": {
      "description": "A local policy rule violation detected in an audit report.",
      "properties": {
        "rule": {
          "title": "Rule",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "server_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Server Name"
        },
        "tool_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Name"
        },
        "severity": {
          "default": "high",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "rule",
        "message"
      ],
      "title": "PolicyViolation",
      "type": "object"
    },
    "PromptInfo": {
      "description": "A prompt exposed by an MCP server.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "arguments": {
          "items": {
            "type": "string"
          },
          "title": "Arguments",
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "PromptInfo",
      "type": "object"
    },
    "ProvenanceFinding": {
      "description": "A launch-config / provenance change detected against the pin baseline.\n\nFires when a server's LAUNCH configuration changed since it was pinned \u2014 a\nsupply-chain signal independent of the tool schemas:\n  COMMAND      \u2014 the command/binary or transport changed (HIGH).\n  ARGS         \u2014 the launch arguments changed: version float, package swap,\n                 or a new flag.  MEDIUM, or HIGH if a known-dangerous flag was\n                 gained.\n  URL          \u2014 the HTTP endpoint/URL changed (HIGH).\n  CREDENTIALS  \u2014 the declared env/header KEY-NAME set changed (MEDIUM).\n\nPure delta vs the pinned config snapshot \u2014 an unchanged launch config produces\nnothing.  Credential surface is compared by KEY NAME only; values are never\ncaptured, stored, or displayed.  Requires a pin baseline that includes a\nconfig snapshot (``--provenance-check`` implies a pin comparison; baselines\npinned before this feature are skipped until re-pinned).",
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProvenanceKind"
        },
        "severity": {
          "$ref": "#/$defs/ProvenanceSeverity"
        },
        "server_name": {
          "title": "Server Name",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "baseline": {
          "title": "Baseline",
          "type": "string"
        },
        "current": {
          "title": "Current",
          "type": "string"
        },
        "gained_flags": {
          "items": {
            "type": "string"
          },
          "title": "Gained Flags",
          "type": "array"
        }
      },
      "required": [
        "kind",
        "severity",
        "server_name",
        "summary",
        "baseline",
        "current"
      ],
      "title": "ProvenanceFinding",
      "type": "object"
    },
    "ProvenanceKind": {
      "enum": [
        "command",
        "args",
        "url",
        "credentials"
      ],
      "title": "ProvenanceKind",
      "type": "string"
    },
    "ProvenanceSeverity": {
      "enum": [
        "high",
        "medium"
      ],
      "title": "ProvenanceSeverity",
      "type": "string"
    },
    "ResourceInfo": {
      "description": "A resource exposed by an MCP server.",
      "properties": {
        "uri": {
          "title": "Uri",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "mime_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mime Type"
        }
      },
      "required": [
        "uri"
      ],
      "title": "ResourceInfo",
      "type": "object"
    },
    "RiskScore": {
      "description": "Multi-dimensional risk score for a server.",
      "properties": {
        "composite": {
          "maximum": 10,
          "minimum": 0,
          "title": "Composite",
          "type": "number"
        },
        "file_access": {
          "maximum": 10,
          "minimum": 0,
          "title": "File Access",
          "type": "number"
        },
        "network_access": {
          "maximum": 10,
          "minimum": 0,
          "title": "Network Access",
          "type": "number"
        },
        "shell_execution": {
          "maximum": 10,
          "minimum": 0,
          "title": "Shell Execution",
          "type": "number"
        },
        "destructive": {
          "maximum": 10,
          "minimum": 0,
          "title": "Destructive",
          "type": "number"
        },
        "exfiltration": {
          "maximum": 10,
          "minimum": 0,
          "title": "Exfiltration",
          "type": "number"
        }
      },
      "required": [
        "composite",
        "file_access",
        "network_access",
        "shell_execution",
        "destructive",
        "exfiltration"
      ],
      "title": "RiskScore",
      "type": "object"
    },
    "ServerAudit": {
      "description": "Complete audit result for a single MCP server.",
      "properties": {
        "server": {
          "$ref": "#/$defs/ServerConfig"
        },
        "connection_status": {
          "title": "Connection Status",
          "type": "string"
        },
        "connection_error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Connection Error"
        },
        "tools": {
          "items": {
            "$ref": "#/$defs/ToolInfo"
          },
          "title": "Tools",
          "type": "array"
        },
        "prompts": {
          "items": {
            "$ref": "#/$defs/PromptInfo"
          },
          "title": "Prompts",
          "type": "array"
        },
        "resources": {
          "items": {
            "$ref": "#/$defs/ResourceInfo"
          },
          "title": "Resources",
          "type": "array"
        },
        "permissions": {
          "items": {
            "$ref": "#/$defs/PermissionFinding"
          },
          "title": "Permissions",
          "type": "array"
        },
        "capability_findings": {
          "items": {
            "$ref": "#/$defs/CapabilityFinding"
          },
          "title": "Capability Findings",
          "type": "array"
        },
        "risk_score": {
          "anyOf": [
            {
              "$ref": "#/$defs/RiskScore"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "non_tool_risk": {
          "anyOf": [
            {
              "$ref": "#/$defs/NonToolRisk"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "has_annotations": {
          "default": false,
          "title": "Has Annotations",
          "type": "boolean"
        },
        "annotation_coverage": {
          "default": 0.0,
          "title": "Annotation Coverage",
          "type": "number"
        },
        "injection_findings": {
          "items": {
            "$ref": "#/$defs/InjectionFinding"
          },
          "title": "Injection Findings",
          "type": "array"
        },
        "ssrf_findings": {
          "items": {
            "$ref": "#/$defs/SsrfFinding"
          },
          "title": "Ssrf Findings",
          "type": "array"
        },
        "drift_findings": {
          "items": {
            "$ref": "#/$defs/DriftFinding"
          },
          "title": "Drift Findings",
          "type": "array"
        },
        "trifecta_findings": {
          "items": {
            "$ref": "#/$defs/TrifectaFinding"
          },
          "title": "Trifecta Findings",
          "type": "array"
        },
        "escalation_findings": {
          "items": {
            "$ref": "#/$defs/EscalationFinding"
          },
          "title": "Escalation Findings",
          "type": "array"
        },
        "provenance_findings": {
