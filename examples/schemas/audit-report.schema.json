    "ShadowingFinding": {
      "description": "A cross-server tool-name shadowing finding.\n\nFires when \u22652 servers expose tools with colliding or confusable names,\npotentially allowing an AI agent to be tricked into routing a call to the\nwrong (possibly malicious) server.  Fleet-level only \u2014 tool names are\nunique within a single server by the MCP spec.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/ShadowingKind"
        },
        "severity": {
          "$ref": "#/$defs/ShadowingSeverity"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "collisions": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "type": "array"
          },
          "title": "Collisions",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "severity",
        "name",
        "collisions",
        "description"
      ],
      "title": "ShadowingFinding",
      "type": "object"
    },
