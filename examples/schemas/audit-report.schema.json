      "enum": [
        "high",
        "medium",
        "low"
      ],
      "title": "ShadowingSeverity",
      "type": "string"
    },
    "SsrfFinding": {
      "description": "A server-side request forgery (SSRF) capability detected in a tool or resource.\n\nFlags interfaces where the server may perform a fetch to a caller-influenceable\nnetwork target (URL/host/endpoint). Static, schema-derived signal only \u2014 no\nrequest is ever made and no credential value is read.",
      "properties": {
        "target_type": {
          "$ref": "#/$defs/CapabilityTarget",
